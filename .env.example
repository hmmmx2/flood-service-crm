# Copy this file to .env and fill in real values
# Never commit .env to git
# Service: flood-service-crm — Port 4002

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4002
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local Docker:  jdbc:postgresql://localhost:5434/flood_crm?user=flood&password=flood
# Neon (cloud):  jdbc:postgresql://HOST/DBNAME?sslmode=require&user=USER&password=PASS
DATABASE_URL=jdbc:postgresql://localhost:5434/flood_crm?user=flood&password=flood

# Docker Compose DB credentials (only needed when using docker-compose up)
DB_USER=flood
DB_PASSWORD=flood

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker: redis://localhost:6381
# Upstash:      rediss://default:TOKEN@HOST:PORT
# Leave empty to use in-memory cache (no Redis needed for local dev without Docker)
REDIS_URL=redis://localhost:6381

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_another_random_64_char_hex_string

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Leave empty in development — emails are logged to console instead
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
DEV_EMAIL_RECIPIENT=
